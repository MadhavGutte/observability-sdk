{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@src/*": ["src/*"]
    }
  },
  "include": ["src/**/*", "tests/**/*", "vitest.config.ts"]
}
