{
  "name": "@madhavgutte/observability-sdk",
  "version": "1.1.1",
  "description": "Production-grade Node.js SDK for emitting observability events to a MySQL ingest proxy",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "observability",
    "metrics",
    "telemetry",
    "events",
    "mysql",
    "ingest"
  ],
  "author": "Madhav Gutte <guttemadhav@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MadhavGutte/observability-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/MadhavGutte/observability-sdk/issues"
  },
  "homepage": "https://github.com/MadhavGutte/observability-sdk#readme"
}
