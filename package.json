{
  "name": "@madhavgutte/observability-sdk",
  "version": "1.0.0",
  "description": "Production-grade Node.js SDK for emitting observability events to Prometheus and ClickHouse",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "observability",
    "metrics",
    "prometheus",
    "clickhouse",
    "telemetry",
    "events"
  ],
  "author": "Madhav Gutte <guttemadhav@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MadhavGutte/observability-sdk.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "prom-client": "^15.1.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "directories": {
    "example": "examples",
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/MadhavGutte/observability-sdk/issues"
  },
  "homepage": "https://github.com/MadhavGutte/observability-sdk#readme"
}
